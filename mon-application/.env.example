VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend server (Express) URL used for Checkout / migration endpoints
VITE_BACKEND_URL=http://localhost:4242

# Stripe publishable key (safe to expose client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe hosted payment link (fallback if backend Checkout is unavailable)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link_here
